# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/concursomundial

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="World Cup 2026 <your_email@gmail.com>"

# Admin Seed
ADMIN_NAME=test
ADMIN_NICKNAME=test
ADMIN_EMAIL=test@test.com
ADMIN_PASSWORD=test

# TheSportsDB (free key is 123, use a paid key for higher rate limits)
SPORTSDB_API_KEY=123

# Minio (S3-compatible image storage)
MINIO_ENDPOINT=https://your-minio.example.com
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=worldcup2026
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=https://your-minio.example.com/worldcup2026

# Redis (optional — used to cache presigned Minio URLs)
REDIS_URL=redis://user:password@host:port/db

FOOTBALL_DATA_API_KEY=ENTER_YOUR_FOOTBALL_DATA_API_KEY_HERE
